# Copy this file to `.env` and fill in your Supabase project values.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional default test user shown via the "Use test account" button on the login page.
# Create this user in your Supabase project (Auth > Users) before using it.
# WARNING: For LOCAL DEVELOPMENT ONLY. The placeholder password below is intentionally
# weak; always override it with a strong value in any shared, staging, or production env.
VITE_TEST_USER_EMAIL=test@optifact.local
VITE_TEST_USER_PASSWORD=password123
