# Copy this file to `.env` and fill in your Optifact API gateway values.
# Base URL of the Optifact api-gateway (no trailing slash).
VITE_API_GATEWAY_URL=https://hycvkzijiwnmcwejvugj.supabase.co/functions/v1/api-gateway
# Project API key (sent in the `x-api-key` header on every request).
# Replace with your own key — the placeholder below is just illustrative.
VITE_API_GATEWAY_KEY=YOUR-API-KEY

# Optional default test user shown via the "Use test account" button on the login page.
# Create this user (POST /register) before using it.
# WARNING: For LOCAL DEVELOPMENT ONLY. The placeholder password below is intentionally
# weak; always override it with a strong value in any shared, staging, or production env.
VITE_TEST_USER_EMAIL=test@optifact.local
VITE_TEST_USER_PASSWORD=password123
